{
  "name": "@krizad/thai-financial-holiday-helper",
  "version": "1.0.1",
  "description": "Thai Financial Institution Holidays synced from Bank of Thailand API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "data/holidays.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "sync": "ts-node scripts/sync.ts",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "thai",
    "thailand",
    "วันหยุด",
    "วันหยุดธนาคาร",
    "วันหยุดสถาบันการเงิน",
    "วันทำการ",
    "วันทำการธนกิจ",
    "ธนาคารแห่งประเทศไทย",
    "ธปท",
    "holiday",
    "financial",
    "bank",
    "bot",
    "business-day",
    "banking-holiday",
    "set-holiday",
    "thai-holiday",
    "thai-calendar",
    "songkran",
    "สงกรานต์",
    "มาฆบูชา",
    "วิสาขบูชา",
    "อาสาฬหบูชา",
    "วันขึ้นปีใหม่",
    "วันแรงงานแห่งชาติ",
    "วันฉัตรมงคล",
    "วันปิยมหาราช",
    "วันรัฐธรรมนูญ"
  ],
  "author": "KriZad",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krizad/thai-financial-holiday-helper-package.git"
  },
  "bugs": {
    "url": "https://github.com/krizad/thai-financial-holiday-helper-package/issues"
  },
  "homepage": "https://krizad.github.io/thai-financial-holiday-helper-demo/",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@vitest/coverage-v8": "^1.3.1",
    "axios": "^1.6.7",
    "dotenv": "^16.4.5",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
